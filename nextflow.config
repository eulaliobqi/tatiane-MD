/*
 * Configuracao principal do pipeline Tatiana-MD
 * Receptor 2I9T (NF-kB) + ligante daidzeina (UNL) — CHARMM36m + CGenFF 5.0
 */

params {
    // --- Entrada/Saida ---
    input          = "${projectDir}/assets/samplesheet.csv"
    outdir         = "${System.getenv('HOME')}/gromacs/results-tatiana"

    // --- Parametros fisicos (alvo humano — NAO copiar defaults dos
    //     pipelines de inseto deste laboratorio, ver README.md) ---
    pH             = 7.4
    time_ns        = 100
    forcefield     = 'charmm36-feb2026_cgenff-5.0'
    water          = 'tip3p'
    nacl_conc      = 0.15   // fisiologico humano (lab usa 0.10 KCl so p/ inseto)
    cation         = 'NA'   // "usar NA para mamiferos" — ja documentado em MD-gromacs/nextflow.config
    temperature    = 300
    box_dist       = 1.2    // nm; padrao do tutorial CHARMM36 p/ complexo globular+molecula pequena
    window_ns      = 5.0    // janela da media movel nos graficos (ns)
    box_type       = 'cubic'

    // --- Residuos de interesse (docking AutoDock Vina, numeracao original
    //     do receptor, cadeia A) ---
    res_arg30      = 30    // contato hidrofobico, 4.7-4.8 A no docking
    res_glu279     = 279   // ligacao de hidrogenio, 1.9 A no docking

    // --- MM-GBSA (gmx_MMPBSA, env mmgbsa-env) ---
    // interval e o knob que controla o tempo de execucao — ajustar apos ver
    // o numero real de frames no primeiro mmgbsa_validation.txt
    mmgbsa_startframe = 1
    mmgbsa_endframe   = 9999999   // gmx_MMPBSA para no ultimo frame real
    mmgbsa_interval   = 10

    // --- Divisao de fase (PHASE_SPLIT) — limites EXATOS da corrida real de
    //     2026-07-13, achados na analise pos-hoc de 2026-07-14 (ver memoria
    //     do projeto). NAO sao deteccao automatica de plateau (ver
    //     comentario em modules/local/phase_split/main.nf) — se rodar de
    //     novo com seed/parametros diferentes, reavaliar a partir dos
    //     graficos antes de reusar estes valores.
    phase_bound_end_ns   = 60   // 0-60ns: pose de docking mantida (Arg30/Glu279 concordam)
    phase_reloc_start_ns = 65   // 65ns-fim: ligante ja migrou pro sitio novo

    // --- Analises extras (clustering + contact_map + prolif + energia de
    //     interacao/Interaction Entropy), rodando uma vez por fase ---
    cluster_cutoff         = 0.2  // cutoff RMSD em nm (GROMOS)
    fe_n_clusters           = 3   // clusters mais populosos a usar no rerun de energia
    fe_frames_per_cluster   = 50  // frames por cluster -> ~150 frames total por fase

    // --- GROMACS ---
    gmx_cmd        = 'gmx_mpi'      // build conda-forge com CUDA usa gmx_mpi
    mpi_cmd        = 'mpirun -np 1' // 1 rank MPI + ntomp threads OpenMP
    use_gpu        = true
    gpu_id         = 0
    ntomp          = 8
    maxwarn        = 2
}

// Carrega configuracoes por perfil
profiles {
    local   { includeConfig 'conf/local.config'  }
    slurm   { includeConfig 'conf/slurm.config'  }
    conda   {
        conda.enabled          = true
        conda.useMamba         = true
        process.conda          = "${System.getenv('HOME')}/miniforge3/envs/md-gromacs"
        process {
            withName: 'MMGBSA' {
                conda = "${System.getenv('HOME')}/miniforge3/envs/mmgbsa-env"
            }
            // bin/plot_results.py importa matplotlib/numpy — NAO instalar isso
            // no md-gromacs (env grande, GROMACS CUDA + AmberTools): ja
            // corrompeu silenciosamente uma vez no projeto irmao Milena-MD
            // (2026-07-02). Env dedicado leve, proprio deste projeto (nao
            // reusar o plot-env do Milena-MD — projetos de execucao ficam
            // isolados, so memoria/agentes/skills sao compartilhados).
            // Criar antes de rodar:
            //   mamba create -n plot-env-tatiana python=3.11 numpy matplotlib -y
            withName: 'PLOT' {
                conda = "${System.getenv('HOME')}/miniforge3/envs/plot-env-tatiana"
            }

            // CONTACT_MAP/PROLIF_FINGERPRINT precisam de MDAnalysis+prolif+
            // rdkit — env dedicado e leve, mesma licao do plot-env-tatiana
            // (nunca instalar isso no md-gromacs grande). Criar antes de
            // rodar: mamba env create -f environment-interact.yml
            withName: 'CONTACT_MAP' {
                conda = "${System.getenv('HOME')}/miniforge3/envs/interact-env-tatiana"
            }
            withName: 'PROLIF_FINGERPRINT' {
                conda = "${System.getenv('HOME')}/miniforge3/envs/interact-env-tatiana"
            }

            // FE_INTERPRET so precisa de numpy/matplotlib — reusa o
            // plot-env-tatiana ja existente (mesma logica do Milena-MD).
            // FE_RERUN fica no md-gromacs padrao (GROMACS puro).
            withName: 'FE_INTERPRET' {
                conda = "${System.getenv('HOME')}/miniforge3/envs/plot-env-tatiana"
            }
        }
    }
}

// Configuracao base de recursos
includeConfig 'conf/base.config'

// Relatorio de execucao
report {
    enabled = true
    file    = "${params.outdir}/pipeline_report.html"
}
timeline {
    enabled = true
    file    = "${params.outdir}/timeline.html"
}
dag {
    enabled = true
    file    = "${params.outdir}/dag.svg"
}

manifest {
    name            = 'Tatiana-MD'
    description     = 'Dinamica Molecular — Receptor 2I9T (NF-kB) + Daidzeina (CHARMM36+CGenFF)'
    version         = '1.0.0'
    nextflowVersion = '>=23.04'
}
