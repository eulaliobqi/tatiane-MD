/*
 * Execucao em cluster SLURM (servidor HPC)
 * Ajuste as filas (queue) conforme o seu cluster.
 */
process {
    executor = 'slurm'

    withLabel: 'process_low' {
        queue  = 'cpu'
        cpus   = 2
        memory = '4.GB'
        time   = '1.h'
    }
    withLabel: 'process_medium' {
        queue  = 'cpu'
        cpus   = 4
        memory = '8.GB'
        time   = '4.h'
    }
    withLabel: 'process_gpu' {
        queue       = 'gpu'
        cpus        = 8
        memory      = '16.GB'
        time        = '48.h'
        clusterOptions = '--gres=gpu:1'
    }
    withLabel: 'process_gpu_long' {
        queue       = 'gpu'
        cpus        = 8
        memory      = '32.GB'
        time        = '120.h'
        clusterOptions = '--gres=gpu:1'
    }
    withLabel: 'process_mmgbsa' {
        queue  = 'cpu'
        cpus   = 8
        memory = '16.GB'
        time   = '72.h'
    }
}

executor {
    queueSize    = 50
    pollInterval = '30 sec'
    submitRateLimit = '10/1min'
}
